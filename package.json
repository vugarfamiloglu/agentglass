{
  "name": "agentglass",
  "version": "0.1.0",
  "description": "The glass box for your AI agents — capture, inspect, replay, and analyze every agent run. Point your agent at AgentGlass and see everything.",
  "type": "module",
  "bin": {
    "agentglass": "dist/index.js"
  },
  "files": [
    "dist",
    "web/dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai",
    "agents",
    "observability",
    "llm",
    "tracing",
    "devtools",
    "anthropic",
    "openai",
    "claude",
    "mcp"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "npm --prefix web run dev",
    "build": "npm --prefix web run build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && npm --prefix web run typecheck"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.1.1",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
